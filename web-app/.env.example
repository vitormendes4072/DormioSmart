# Copie este arquivo para .env e preencha com os valores reais.
# O .env real NUNCA é versionado (está no .gitignore). Este .example SIM.

# Supabase — projeto: Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co

# O backend (Flask) é server-side e usa a chave service_role (full-access),
# mantendo o RLS ligado no banco. NUNCA commitar, logar ou expor esta chave:
# ela vive apenas no .env local (ignorado) e nas variáveis de ambiente do
# servidor (Vercel). Se vazar, rotacione imediatamente no Supabase.
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-secreta-aqui

# A chave anon (pública) NÃO é usada por este backend, pois o navegador não
# acessa o Supabase diretamente. Mantida apenas como fallback opcional.
# SUPABASE_KEY=sua-chave-anon-publica-aqui

# Flask
FLASK_ENV=development
