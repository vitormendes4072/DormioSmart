# Copie este arquivo para .env e preencha com os valores reais.
# O .env real NUNCA é versionado (está no .gitignore). Este .example SIM.

# Supabase — projeto: Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_KEY=sua-chave-anon-publica-aqui

# A chave service_role (full-access) NÃO entra aqui nem em nenhum cliente.
# Se o backend precisar dela, use uma variável separada apenas em ambiente de servidor:
# SUPABASE_SERVICE_ROLE_KEY=

# Flask
FLASK_ENV=development
